# 这里只提供变量名称和非敏感示例。任何真实密码、令牌和访问密钥都不得写入该文件。
AGENTMIND_BACKEND_IMAGE=registry.example.com/agentmind/backend:0.1.0
AGENTMIND_CANARY_IMAGE=registry.example.com/agentmind/backend:0.1.0
AGENTMIND_SECURITY_MODE=oidc
AGENTMIND_OIDC_ISSUER_URI=https://identity.example.com/realms/agentmind
AGENTMIND_OIDC_AUDIENCE=agentmind-api
AGENTMIND_DATABASE_URL=jdbc:postgresql://postgres.example.com:5432/agentmind
AGENTMIND_DATABASE_USERNAME=agentmind
AGENTMIND_REDIS_HOST=redis.example.com
AGENTMIND_REDIS_PORT=6379
AGENTMIND_REDIS_SSL=true
AGENTMIND_MINIO_ENDPOINT=https://minio.example.com
AGENTMIND_MINIO_BUCKET=agentmind
AGENTMIND_OPENSEARCH_URL=https://opensearch.example.com
AGENTMIND_OPENSEARCH_USERNAME=agentmind
AGENTMIND_ALLOWED_ORIGIN=https://knowledge.example.com
AGENTMIND_TRUSTED_PROXY_CIDRS=10.0.0.0/8
AGENTMIND_OTLP_TRACING_ENDPOINT=https://otel.example.com/v1/traces
AGENTMIND_FLASHCARD_WEB_SEARCH_ENABLED=false
AGENTMIND_WEB_SEARCH_BASE_URL=https://api.search.brave.com
AGENTMIND_WEB_SEARCH_API_KEY=
AGENTMIND_WEB_SEARCH_RESULT_COUNT=3
