{
  "realm": "agentmind",
  "enabled": true,
  "sslRequired": "none",
  "clients": [
    {
      "clientId": "agentmind-test",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "uid",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "uid",
            "claim.name": "uid",
            "jsonType.label": "long",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "agentmind-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "agentmind-api",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "oidc-user",
      "enabled": true,
      "firstName": "OIDC",
      "lastName": "Tester",
      "email": "oidc-user@example.com",
      "emailVerified": true,
      "requiredActions": [],
      "attributes": {
        "uid": ["1001"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "oidc-test-password",
          "temporary": false
        }
      ]
    }
  ]
}
