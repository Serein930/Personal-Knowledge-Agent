# 本文件只描述预发布运行时的非秘密配置，不得在此填写密码、令牌、私钥或访问密钥。
# 使用时复制到受保护部署节点的仓库外目录，由变更系统注入当前进程。

AGENTMIND_SECURITY_MODE=oidc
AGENTMIND_OIDC_ISSUER_URI=https://替换为真实身份提供方/
AGENTMIND_OIDC_AUDIENCE=agentmind-api

AGENTMIND_DATABASE_URL=jdbc:postgresql://替换为PostgreSQL地址:5432/agentmind
AGENTMIND_DATABASE_USERNAME=agentmind
AGENTMIND_REDIS_HOST=替换为Redis地址
AGENTMIND_REDIS_PORT=6379
AGENTMIND_REDIS_SSL=true

AGENTMIND_MINIO_ENDPOINT=https://替换为MinIO地址
AGENTMIND_MINIO_BUCKET=agentmind
AGENTMIND_OPENSEARCH_URL=https://替换为OpenSearch地址
AGENTMIND_OPENSEARCH_USERNAME=agentmind

AGENTMIND_ALLOWED_ORIGIN=https://替换为前端验收域名
AGENTMIND_TRUSTED_PROXY_CIDRS=替换为网关覆盖网络CIDR
AGENTMIND_TRACING_ENABLED=true
AGENTMIND_OTLP_TRACING_ENDPOINT=https://替换为OTLP采集地址/v1/traces

# 首次部署时稳定组和灰度组使用同一个带摘要镜像；后续灰度由工作流单独更新。
AGENTMIND_BACKEND_IMAGE=ghcr.io/serein930/personal-knowledge-agent/backend@sha256:替换为六十四位摘要
AGENTMIND_CANARY_IMAGE=ghcr.io/serein930/personal-knowledge-agent/backend@sha256:替换为六十四位摘要
